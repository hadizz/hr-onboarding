OPENAI_API_KEY=sk-your-key-here

# Local dev (outside Docker) — host is localhost
POSTGRES_USER=onboardai
POSTGRES_PASSWORD=onboardai
POSTGRES_DB=onboardai
DATABASE_URL=postgresql://onboardai:onboardai@localhost:5432/onboardai

# Docker Compose reads POSTGRES_* from this file and rewrites DATABASE_URL
# to use host `postgres` inside containers.

# pgAdmin UI at http://localhost:8080
PGADMIN_DEFAULT_EMAIL=admin@onboardai.com
PGADMIN_DEFAULT_PASSWORD=admin
